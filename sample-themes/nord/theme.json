{
    "name": "Nord",
    "version": "1.0.0",
    "description": "An arctic, north-bluish clean and elegant theme.",
    "author": "takakix2",
    "prompts": {
        "left": "{color:prompt_primary}{user}@{host}{color:muted}:{color:prompt_secondary}{cwd}{reset} ❯ ",
        "right": "{clock}",
        "continuation": "> ",
        "title": "hsh: {cwd}"
    },
    "colors": {
        "background": "#2e3440",
        "foreground": "#d8dee9",
        "prompt_primary": "#88c0d0",
        "prompt_secondary": "#ebcb8b",
        "success": "#a3be8c",
        "error": "#bf616a",
        "info": "#81a1c1",
        "muted": "#4c566a"
    },
    "syntax": {
        "keyword": "#bf616a",
        "string": "#a3be8c",
        "method": "#88c0d0",
        "comment": "#4c566a"
    },
    "widgets": [
        "clock"
    ],
    "cursor_style": "block",
    "requires_nerd_fonts": false
}